@model Absence.Models.T_Matiere

<h2>Edit Subject</h2>

<form asp-action="Edit" method="post">
    <div class="form-group">
        <label asp-for="NomMatiere">Subject Name</label>
        <input asp-for="NomMatiere" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="NbrHeureCoursParSemaine">Course Hours/Week</label>
        <input asp-for="NbrHeureCoursParSemaine" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="NbrHeureTDParSemaine">TD Hours/Week</label>
        <input asp-for="NbrHeureTDParSemaine" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="NbrHeureTPParSemaine">TP Hours/Week</label>
        <input asp-for="NbrHeureTPParSemaine" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Edit</button>
</form>